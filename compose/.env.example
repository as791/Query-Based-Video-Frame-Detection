# ─── Google OAuth2 ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-oauth2-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth2-client-secret

# ─── AWS credentials (S3 + KMS) ───────────────────────────────────────────────
# IAM permissions needed:
#   s3:PutObject, s3:GetObject, s3:DeleteObject, s3:ListBucket, s3:GeneratePresignedUrl
#   kms:CreateKey, kms:CreateAlias, kms:DescribeKey, kms:TagResource,
#   kms:GenerateDataKey, kms:Decrypt
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# ─── S3 ───────────────────────────────────────────────────────────────────────
S3_BUCKET=stage-video-bucket

# ─── KMS (per-user encryption keys) ──────────────────────────────────────────
KMS_KEY_ALIAS_PREFIX=alias/vvault/user/
# Can be the same as AWS_ACCESS_KEY_ID if that user has KMS permissions too
KMS_AWS_ACCESS_KEY_ID=your-aws-access-key-id
KMS_AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# ─── ML models ────────────────────────────────────────────────────────────────
SIGLIP_MODEL=google/siglip2-base-patch16-224

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://mongo:27017/videovault

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URI=redis://redis:6379

# ─── PostgreSQL (users + sessions) ───────────────────────────────────────────
POSTGRES_URL=jdbc:postgresql://postgres:5432/videovault
POSTGRES_USER=videovault
POSTGRES_PASSWORD=videovault

# ─── Service URLs (internal docker network) ───────────────────────────────────
SEARCH_SERVICE_URL=http://mlservice:8000/search
EMBEDDER_URL=http://embedder:8002
QDRANT_URL=http://qdrant:6333
FRONTEND_ORIGIN=http://localhost:3000

# ─── VLM (Vision-Language Model — OpenAI-compatible endpoint) ────────────────
# Options:
#   Local Ollama (default, Apple Silicon Metal acceleration):
#     VLM_URL=http://host.docker.internal:11434
#     VLM_MODEL=qwen2.5vl:7b      # or llava:7b, minicpm-v:8b, etc.
#   OpenAI-hosted:
#     VLM_URL=https://api.openai.com
#     VLM_MODEL=gpt-4o-mini
#   Remote vLLM (GPU host):
#     VLM_URL=https://your-vllm-host
#     VLM_MODEL=Qwen/Qwen2.5-VL-7B-AWQ
VLM_URL=http://host.docker.internal:11434
VLM_MODEL=qwen2.5vl:7b
